# ---- BGE / Embedding ----
# BGE-M3 model id (HuggingFace). Override to use a local path.
BGE_M3_MODEL_NAME=BAAI/bge-m3
# BGE reranker model id
BGE_RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
# Device: mps (Apple Silicon) | cuda | cpu
EMBED_DEVICE=mps
# HuggingFace cache directory (overrides default ~/.cache/huggingface).
# Set this to a pre-populated directory to avoid network downloads.
HF_HOME=./storage/models

# ---- Storage ----
STORAGE_DIR=./storage
COLLECTION_NAME=hybrid_rag

# ---- Ollama ----
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT=300